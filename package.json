{
  "name": "flamemail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "generate-types": "wrangler types --env-file .dev.vars.example",
    "check": "npm run generate-types && tsc --noEmit -p tsconfig.json && tsc --noEmit -p tests/tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run --project client --project worker --project scripts",
    "test:watch": "vitest --project client --project worker --project scripts",
    "test:client": "vitest run --project client",
    "test:worker": "vitest run --project worker",
    "test:scripts": "vitest run --project scripts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:ci": "npm run format:check && npm run check && npm run test",
    "cf:typegen": "npm run generate-types",
    "oidc:local": "oidc-mock-provider --host localhost --port 5174 --payload \"{\\\"sub\\\":\\\"7980f89b-9969-48ac-a767-35695f305157\\\"}\" --expiry 300 --skip-refresh-token",
    "email:local": "node ./scripts/send-local-email.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply flamemail-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply flamemail-db --local",
    "db:push": "drizzle-kit push",
    "db:local:migrate": "npm run db:migrate:local",
    "db:local:init": "npm run db:migrate:local",
    "db:local:reset": "node ./scripts/reset-local-d1.mjs && npm run db:migrate:local",
    "deploy": "npm run db:migrate && npm run build && wrangler deploy",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@cloudflare/util-en-garde": "^8.0.14",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.18",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.11",
    "openid-client": "^6.8.4",
    "postal-mime": "^2.7.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.4",
    "@cloudflare/vitest-pool-workers": "^0.16.4",
    "@mongodb-js/oidc-mock-provider": "^0.13.12",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.1"
  }
}
